<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarLessonPlayer"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/glass_toolbar"
        app:navigationIcon="@drawable/common_ic_arrow_back"
        app:navigationIconTint="@color/smartkid_text"
        app:title="@string/lesson_content"
        app:titleTextColor="@color/smartkid_text" />

    <ProgressBar
        android:id="@+id/progressLessonLoading"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:indeterminate="true"
        android:visibility="gone" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/screen_padding_compact"
            android:background="@drawable/common_bg_glass_card"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:background="@null"
                android:id="@+id/textLessonContentType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/lesson_content"
                android:textColor="@color/smartkid_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:background="@null"
                android:id="@+id/textLessonContentStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="@string/lesson_not_completed"
                android:textColor="@color/smartkid_success"
                android:textSize="13sp" />

            <VideoView
                android:id="@+id/videoLesson"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="14dp"
                android:background="@color/black"
                android:contentDescription="@string/lesson_content"
                android:visibility="gone" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/common_bg_glass_card"
                android:clipToOutline="true"
                android:elevation="@dimen/glass_elevation">

                <TextView
                    android:background="@null"
                    android:id="@+id/textLessonContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="130dp"
                    android:padding="18dp"
                    android:text="@string/no_text_content"
                    android:textColor="@color/smartkid_text"
                    android:textIsSelectable="true"
                    android:textSize="16sp"
                    android:lineSpacingExtra="5dp" />
            </FrameLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonOpenExternal"
                style="@style/Widget.Smartkid.GlassButton.Outlined"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="14dp"
                android:text="@string/open_content"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonSpeakLesson"
                style="@style/Widget.Smartkid.GlassButton.Outlined"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:enabled="false"
                android:text="@string/speak_content" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonLessonDiscussion"
                style="@style/Widget.Smartkid.GlassButton.Outlined"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:text="@string/lesson_discussion" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonLessonAiTutor"
                style="@style/Widget.Smartkid.GlassButton.Outlined"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:text="@string/ai_tutor" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonCompleteLesson"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp"
                android:enabled="false"
                android:text="@string/mark_completed"
                app:cornerRadius="@dimen/glass_radius_large" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
