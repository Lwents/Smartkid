<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarLearningAnalysis"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/glass_toolbar"
        app:navigationIcon="@drawable/common_ic_arrow_back"
        app:navigationIconTint="@color/smartkid_text"
        app:title="@string/learning_analysis"
        app:titleTextColor="@color/smartkid_text" />
    <ProgressBar
        android:id="@+id/progressLearningAnalysis"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:indeterminate="true"
        android:visibility="gone" />
    <TextView
        android:id="@+id/textLearningAnalysisSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="14dp"
        android:background="@drawable/common_bg_secondary_gradient"
        android:padding="16dp"
        android:textColor="@color/on_secondary"
        android:textSize="15sp"
        android:lineSpacingExtra="5dp" />
    <TextView
        android:background="@null"
        android:id="@+id/textLearningAnalysisStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp"
        android:textColor="@color/smartkid_text_secondary" />
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <ListView
            android:id="@+id/listLearningSuggestions"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:divider="@android:color/transparent"
            android:dividerHeight="8dp"
            android:padding="12dp" />
        <TextView
            android:background="@null"
            android:id="@+id/textLearningSuggestionsEmpty"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:padding="24dp"
            android:text="@string/no_suggested_lessons"
            android:textColor="@color/smartkid_text_secondary" />
    </FrameLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonStartAssessment"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="@string/entry_assessment" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonRestoreStreak"
            style="@style/Widget.Smartkid.GlassButton.Outlined"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="6dp"
            android:text="@string/restore_streak" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonLearningAnalysisRefresh"
            style="@style/Widget.Smartkid.GlassButton.Outlined"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="6dp"
            android:text="@string/refresh" />
    </LinearLayout>
</LinearLayout>
