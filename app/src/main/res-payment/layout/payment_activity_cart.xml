<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarCart"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/glass_toolbar"
        app:navigationIcon="@drawable/common_ic_arrow_back"
        app:navigationIconTint="@color/smartkid_text"
        app:title="@string/cart"
        app:titleTextColor="@color/smartkid_text" />
    <ProgressBar
        android:id="@+id/progressCart"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:indeterminate="true"
        android:visibility="gone" />
    <TextView
        android:background="@null"
        android:id="@+id/textCartStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:textColor="@color/smartkid_text_secondary"
        android:visibility="gone" />
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <ListView
            android:id="@+id/listCart"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:divider="@android:color/transparent"
            android:dividerHeight="8dp"
            android:padding="12dp" />
        <TextView
            android:background="@null"
            android:id="@+id/textCartEmpty"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:padding="24dp"
            android:text="@string/empty_cart"
            android:textColor="@color/smartkid_text_secondary" />
    </FrameLayout>
    <TextView
        android:id="@+id/textCartTotal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/screen_padding_compact"
        android:layout_marginEnd="@dimen/screen_padding_compact"
        android:background="@drawable/common_bg_glass_capsule"
        android:gravity="end"
        android:padding="14dp"
        android:text="@string/cart_total_empty"
        android:textColor="@color/smartkid_text"
        android:textSize="18sp"
        android:textStyle="bold" />
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonCartRefresh"
            style="@style/Widget.Smartkid.GlassButton.Outlined"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="@string/refresh" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonCartCheckout"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:enabled="false"
            android:text="@string/checkout" />
    </LinearLayout>
</LinearLayout>
