<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbarPayment"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/glass_toolbar"
            app:navigationIcon="@drawable/common_ic_arrow_back"
            app:navigationIconTint="@color/smartkid_text"
            app:title="@string/make_payment"
            app:titleTextColor="@color/smartkid_text" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/screen_padding_compact"
            android:background="@drawable/common_bg_glass_card"
            android:orientation="vertical"
            android:padding="22dp">
            <TextView
                android:background="@null"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/payment_real_note"
                android:textColor="@color/smartkid_text_secondary" />
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Smartkid.GlassInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:hint="@string/amount_hint">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/inputPaymentAmount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Smartkid.GlassInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/payment_description_hint">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/inputPaymentDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapSentences"
                    android:maxLength="255"
                    android:maxLines="3" />
            </com.google.android.material.textfield.TextInputLayout>
            <TextView
                android:background="@null"
                android:id="@+id/textPaymentStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textColor="@color/smartkid_text"
                android:visibility="gone" />
            <ProgressBar
                android:id="@+id/progressPayment"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:indeterminate="true"
                android:visibility="gone" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonPayMomo"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="18dp"
                android:text="@string/pay_with_momo" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonPaymentHistory"
                style="@style/Widget.Smartkid.GlassButton.Outlined"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:text="@string/payment_history" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
