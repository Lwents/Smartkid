<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="@dimen/floating_nav_content_inset">

        <TextView
            android:id="@+id/textProfileAvatar"
            android:layout_width="92dp"
            android:layout_height="92dp"
            android:background="@drawable/common_bg_avatar"
            android:gravity="center"
            android:text="@string/avatar_default"
            android:textColor="@color/on_primary"
            android:textSize="34sp"
            android:textStyle="bold" />

        <TextView
            android:background="@null"
            android:id="@+id/textProfileName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center"
            android:text="@string/student_default_name"
            android:textColor="@color/smartkid_text"
            android:textSize="23sp"
            android:textStyle="bold" />

        <ProgressBar
            android:id="@+id/progressProfile"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:indeterminate="true"
            android:visibility="gone" />

        <TextView
            android:background="@null"
            android:id="@+id/textProfileStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:textColor="@color/smartkid_text_secondary"
            android:textSize="13sp"
            android:visibility="gone" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/common_bg_glass_card"
            android:clipToOutline="true"
            android:elevation="@dimen/glass_elevation">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:background="@null"
                    android:id="@+id/textProfileUsername"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/smartkid_text"
                    android:textSize="15sp" />

                <TextView
                    android:background="@null"
                    android:id="@+id/textProfileEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="13dp"
                    android:textColor="@color/smartkid_text"
                    android:textSize="15sp" />

                <TextView
                    android:background="@null"
                    android:id="@+id/textProfileClass"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="13dp"
                    android:textColor="@color/smartkid_text"
                    android:textSize="15sp" />

                <TextView
                    android:background="@null"
                    android:id="@+id/textProfileRole"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="13dp"
                    android:textColor="@color/smartkid_text"
                    android:textSize="15sp" />

                <TextView
                    android:background="@null"
                    android:id="@+id/textProfileServer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:textColor="@color/smartkid_text_secondary"
                    android:textIsSelectable="true"
                    android:textSize="12sp" />
            </LinearLayout>
        </FrameLayout>

        <TextView
            android:background="@null"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/student_features"
            android:textColor="@color/smartkid_text"
            android:textSize="17sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonEditProfile"
                style="@style/Widget.Smartkid.GlassButton.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/edit_profile" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonChangePassword"
                style="@style/Widget.Smartkid.GlassButton.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/change_password" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonParentInfo"
                style="@style/Widget.Smartkid.GlassButton.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/parent_info" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonCatalog"
                style="@style/Widget.Smartkid.GlassButton.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/course_catalog" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonLearningPath"
                style="@style/Widget.Smartkid.GlassButton.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/learning_path" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonAiTutor"
                style="@style/Widget.Smartkid.GlassButton.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/ai_tutor" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonLearningAnalysis"
                style="@style/Widget.Smartkid.GlassButton.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/learning_analysis" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonCertificates"
                style="@style/Widget.Smartkid.GlassButton.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/certificates" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonPayments"
                style="@style/Widget.Smartkid.GlassButton.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/payments" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonCart"
                style="@style/Widget.Smartkid.GlassButton.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/cart" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonNotifications"
                style="@style/Widget.Smartkid.GlassButton.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/notifications" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonRefreshProfile"
            style="@style/Widget.Smartkid.GlassButton.Outlined"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="18dp"
            android:text="@string/refresh" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonLogout"
            style="@style/Widget.Smartkid.GlassButton.Outlined"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="9dp"
            android:layout_marginBottom="20dp"
            android:text="@string/logout"
            android:textColor="@color/smartkid_error"
            app:strokeColor="@color/smartkid_error" />
    </LinearLayout>
</ScrollView>
