<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/glass_navigation_active" />
            <stroke android:width="@dimen/glass_stroke_width" android:color="@color/glass_service_stroke" />
            <corners android:radius="@dimen/glass_radius" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/glass_service_tile" />
            <stroke android:width="@dimen/glass_stroke_width" android:color="@color/glass_service_stroke" />
            <corners android:radius="@dimen/glass_radius" />
        </shape>
    </item>
</selector>
