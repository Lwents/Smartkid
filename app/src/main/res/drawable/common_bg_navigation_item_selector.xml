<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:endColor="#A8DCEBFF"
                android:startColor="#C7DFD8FF" />
            <stroke android:width="1dp" android:color="@color/glass_navigation_stroke" />
            <corners android:radius="@dimen/floating_nav_item_radius" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <corners android:radius="@dimen/floating_nav_item_radius" />
        </shape>
    </item>
</selector>
