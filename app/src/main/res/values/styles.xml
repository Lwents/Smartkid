<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="ShapeAppearance.Smartkid.Glass" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/glass_radius</item>
    </style>

    <style name="Widget.Smartkid.GlassCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/glass_surface</item>
        <item name="cardCornerRadius">@dimen/glass_radius</item>
        <item name="cardElevation">@dimen/glass_elevation</item>
        <item name="strokeColor">@color/glass_stroke</item>
        <item name="strokeWidth">@dimen/glass_stroke_width</item>
        <item name="android:clickable">false</item>
    </style>

    <style name="Widget.Smartkid.GlassCard.Interactive" parent="Widget.Smartkid.GlassCard">
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="rippleColor">@color/glass_stroke</item>
    </style>

    <style name="Widget.Smartkid.GlassButton" parent="Widget.Material3.Button">
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="backgroundTint">@color/smartkid_primary</item>
        <item name="android:textColor">@color/on_primary</item>
        <item name="cornerRadius">@dimen/glass_radius_large</item>
        <item name="elevation">2dp</item>
        <item name="rippleColor">@color/glass_stroke</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="Widget.Smartkid.GlassButton.Secondary" parent="Widget.Smartkid.GlassButton">
        <item name="backgroundTint">@color/smartkid_secondary</item>
        <item name="android:textColor">@color/on_secondary</item>
    </style>

    <style name="Widget.Smartkid.GlassButton.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="backgroundTint">@color/glass_surface_soft</item>
        <item name="strokeColor">@color/glass_stroke</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textColor">@color/smartkid_primary</item>
        <item name="cornerRadius">@dimen/glass_radius_large</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="Widget.Smartkid.GlassButton.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:minHeight">@dimen/touch_target</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/smartkid_primary</item>
        <item name="cornerRadius">@dimen/glass_radius_large</item>
    </style>

    <style name="Widget.Smartkid.GlassInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/glass_input</item>
        <item name="boxStrokeColor">@color/smartkid_primary</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="boxCornerRadiusTopStart">@dimen/glass_radius_small</item>
        <item name="boxCornerRadiusTopEnd">@dimen/glass_radius_small</item>
        <item name="boxCornerRadiusBottomStart">@dimen/glass_radius_small</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/glass_radius_small</item>
        <item name="hintTextColor">@color/smartkid_text_secondary</item>
        <item name="android:textColorHint">@color/smartkid_text_secondary</item>
        <item name="endIconTint">@color/smartkid_text_secondary</item>
        <item name="startIconTint">@color/smartkid_primary</item>
    </style>

    <style name="Widget.Smartkid.GlassToolbar" parent="Widget.Material3.Toolbar.Surface">
        <item name="android:background">@color/glass_toolbar</item>
        <item name="titleTextColor">@color/smartkid_text</item>
        <item name="subtitleTextColor">@color/smartkid_text_secondary</item>
        <item name="navigationIconTint">@color/smartkid_text</item>
        <item name="android:elevation">0dp</item>
    </style>

    <style name="Widget.Smartkid.FloatingNavigation" parent="">
        <item name="android:background">@drawable/bg_floating_navigation</item>
        <item name="android:elevation">@dimen/glass_elevation_high</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:padding">5dp</item>
    </style>

    <style name="Widget.Smartkid.FloatingNavigation.Item" parent="">
        <item name="android:background">@drawable/bg_navigation_item_selector</item>
        <item name="android:clickable">true</item>
        <item name="android:drawablePadding">1dp</item>
        <item name="android:focusable">true</item>
        <item name="android:gravity">center</item>
        <item name="android:maxLines">1</item>
        <item name="android:paddingTop">3dp</item>
        <item name="android:paddingBottom">2dp</item>
        <item name="android:textColor">@color/navigation_custom_item_color</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.Smartkid.ServiceTile" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/glass_service_tile</item>
        <item name="cardCornerRadius">@dimen/glass_radius</item>
        <item name="cardElevation">@dimen/glass_elevation</item>
        <item name="strokeColor">@color/glass_service_stroke</item>
        <item name="strokeWidth">@dimen/glass_stroke_width</item>
        <item name="rippleColor">@color/glass_navigation_active</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

    <style name="ThemeOverlay.Smartkid.GlassDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorSurface">@color/glass_surface_strong</item>
        <item name="colorOnSurface">@color/smartkid_text</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.Smartkid.Glass</item>
    </style>

    <style name="ThemeOverlay.Smartkid.GlassBottomSheet" parent="ThemeOverlay.Material3.BottomSheetDialog">
        <item name="colorSurface">@color/glass_surface_strong</item>
        <item name="colorOnSurface">@color/smartkid_text</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.Smartkid.Glass</item>
    </style>

    <style name="TextAppearance.Smartkid.Display" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textColor">@color/smartkid_text</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>

    <style name="TextAppearance.Smartkid.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/smartkid_text</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.Smartkid.Body" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/smartkid_text_secondary</item>
        <item name="android:lineSpacingExtra">2dp</item>
    </style>

    <style name="Animation.Smartkid.Window" parent="@android:style/Animation.Activity">
        <item name="android:activityOpenEnterAnimation">@anim/liquid_fade_in</item>
        <item name="android:activityOpenExitAnimation">@anim/liquid_fade_out</item>
        <item name="android:activityCloseEnterAnimation">@anim/liquid_fade_in</item>
        <item name="android:activityCloseExitAnimation">@anim/liquid_fade_out</item>
    </style>
</resources>
