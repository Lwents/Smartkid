<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarAiTutor"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/glass_toolbar"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="@color/smartkid_text"
        app:subtitleTextColor="@color/smartkid_text_secondary"
        app:title="@string/ai_tutor"
        app:titleTextColor="@color/smartkid_text" />

    <ProgressBar
        android:id="@+id/progressAiTutor"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:indeterminate="true"
        android:visibility="gone" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">
        <TextView
            android:id="@+id/textAiConversation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/screen_padding_compact"
            android:background="@drawable/bg_glass_card"
            android:minHeight="260dp"
            android:padding="20dp"
            android:textColor="@color/smartkid_text"
            android:textIsSelectable="true"
            android:textSize="16sp"
            android:lineSpacingExtra="6dp" />
    </ScrollView>

    <TextView
        android:background="@null"
        android:id="@+id/textAiStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="6dp"
        android:textColor="@color/smartkid_text_secondary"
        android:textSize="13sp"
        android:visibility="gone" />

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.Smartkid.GlassInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/screen_padding_compact"
        android:layout_marginEnd="@dimen/screen_padding_compact"
        android:hint="@string/ai_question_hint">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/inputAiMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textCapSentences|textMultiLine"
            android:maxLength="1000"
            android:maxLines="4" />
    </com.google.android.material.textfield.TextInputLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonAiClear"
            style="@style/Widget.Smartkid.GlassButton.Outlined"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="@string/clear_conversation" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonAiSend"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/send_question" />
    </LinearLayout>
</LinearLayout>
