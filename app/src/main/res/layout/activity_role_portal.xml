<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_primary_gradient"
        android:orientation="vertical"
        android:padding="18dp">
        <TextView
            android:background="@null"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/management_portal_title"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold" />
        <TextView
            android:background="@null"
            android:id="@+id/textRoleWelcome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:textColor="@color/white" />
    </LinearLayout>
    <ListView
        android:id="@+id/listRoleFeatures"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:divider="@android:color/transparent"
        android:dividerHeight="9dp"
        android:padding="14dp" />
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="8dp">
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonRoleProfile"
            style="@style/Widget.Smartkid.GlassButton.Outlined"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/edit_profile" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonRolePassword"
            style="@style/Widget.Smartkid.GlassButton.Outlined"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/change_password" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonRoleLogout"
            style="@style/Widget.Smartkid.GlassButton.Outlined"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/logout"
            android:textColor="@color/smartkid_error"
            app:strokeColor="@color/smartkid_error" />
    </LinearLayout>
</LinearLayout>
