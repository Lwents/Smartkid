<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/screen_padding_compact"
        android:background="@drawable/bg_glass_card_strong"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:background="@null"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/forgot_title"
            android:textColor="@color/smartkid_text"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:background="@null"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/forgot_subtitle"
            android:textColor="@color/smartkid_text_secondary" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Smartkid.GlassInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:hint="@string/email_hint">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/inputForgotEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textEmailAddress"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:background="@null"
            android:id="@+id/textForgotStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@color/smartkid_text"
            android:visibility="gone" />

        <ProgressBar
            android:id="@+id/progressForgot"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:indeterminate="true"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonSendReset"
            style="@style/Widget.Smartkid.GlassButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="18dp"
            android:text="@string/send_reset_email" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonHaveResetToken"
            style="@style/Widget.Smartkid.GlassButton.Outlined"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:text="@string/have_reset_token" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonForgotBack"
            style="@style/Widget.Smartkid.GlassButton.Text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/back_to_login" />
    </LinearLayout>
</ScrollView>
