<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarManagementCreate"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/glass_toolbar"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="@color/smartkid_text"
        app:title="@string/management_create"
        app:titleTextColor="@color/smartkid_text" />
    <ProgressBar
        android:id="@+id/progressManagementCreate"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:indeterminate="true"
        android:visibility="gone" />
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout
            android:id="@+id/containerManagementFields"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/screen_padding_compact"
            android:background="@drawable/bg_glass_card"
            android:orientation="vertical"
            android:padding="20dp" />
    </ScrollView>
    <TextView
        android:background="@null"
        android:id="@+id/textManagementCreateStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp"
        android:textColor="@color/smartkid_error"
        android:visibility="gone" />
    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonManagementCreateSubmit"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_margin="12dp"
        android:text="@string/create_on_server" />
</LinearLayout>
