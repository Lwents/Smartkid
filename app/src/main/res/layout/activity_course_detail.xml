<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarCourseDetail"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/glass_toolbar"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="@color/smartkid_text"
        app:title="@string/course_detail"
        app:titleTextColor="@color/smartkid_text" />

    <ProgressBar
        android:id="@+id/progressCourseDetailLoading"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:indeterminate="true"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/screen_padding_compact"
        android:layout_marginTop="@dimen/space_md"
        android:layout_marginEnd="@dimen/screen_padding_compact"
        android:background="@drawable/bg_glass_card"
        android:orientation="vertical"
        android:paddingStart="@dimen/space_lg"
        android:paddingTop="14dp"
        android:paddingEnd="@dimen/space_lg">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/imageCourseDetail"
                android:layout_width="112dp"
                android:layout_height="112dp"
                android:background="@null"
                android:contentDescription="@string/course_detail"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_course_placeholder" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:background="@null"
                    android:id="@+id/textCourseDetailTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxLines="3"
                    android:text="@string/updating"
                    android:textColor="@color/smartkid_text"
                    android:textSize="19sp"
                    android:textStyle="bold" />

                <TextView
                    android:background="@null"
                    android:id="@+id/textCourseDetailMeta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:textColor="@color/smartkid_primary"
                    android:textSize="13sp" />

                <TextView
                    android:background="@null"
                    android:id="@+id/textCourseDetailTeacher"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/teacher_updating"
                    android:textColor="@color/smartkid_text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:background="@null"
            android:id="@+id/textCourseDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:ellipsize="end"
            android:maxLines="3"
            android:text="@string/no_course_description"
            android:textColor="@color/smartkid_text_secondary"
            android:textSize="13sp" />

        <ProgressBar
            android:id="@+id/progressCourseDetail"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="7dp"
            android:layout_marginTop="12dp"
            android:max="100" />

        <TextView
            android:background="@null"
            android:id="@+id/textCourseDetailProgress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/choose_course_hint"
            android:textColor="@color/smartkid_success"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonStartLearning"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:enabled="false"
                android:text="@string/start_learning"
                app:cornerRadius="@dimen/glass_radius_large" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonRetryCourseDetail"
                style="@style/Widget.Smartkid.GlassButton.Outlined"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:text="@string/retry"
                android:visibility="gone" />
        </LinearLayout>

        <TextView
            android:background="@null"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="8dp"
            android:text="@string/lesson_list"
            android:textColor="@color/smartkid_text"
            android:textSize="17sp"
            android:textStyle="bold" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp">

        <ListView
            android:id="@+id/listLessons"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:divider="@android:color/transparent"
            android:dividerHeight="8dp" />

        <TextView
            android:background="@null"
            android:id="@+id/textLessonsEmpty"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="@string/no_lessons"
            android:textColor="@color/smartkid_text_secondary"
            android:textSize="14sp" />
    </FrameLayout>
</LinearLayout>
