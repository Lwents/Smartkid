<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <TextView
        style="@style/TextAppearance.Smartkid.AdminSectionTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="16dp"
        android:text="@string/role_quick_actions" />
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="11dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="11dp"
        android:columnCount="2">
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/buttonAdminUsers" style="@style/Widget.Smartkid.AdminGlassCard.Interactive"
            android:layout_width="0dp" android:layout_height="62dp" android:layout_columnWeight="1" android:layout_margin="5dp" app:cardCornerRadius="20dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center_vertical" android:orientation="horizontal" android:padding="10dp">
                <FrameLayout android:layout_width="36dp" android:layout_height="36dp" android:background="@drawable/admin_bg_quick_blue">
                    <ImageView android:layout_width="18dp" android:layout_height="18dp" android:layout_gravity="center" android:contentDescription="@null" android:src="@drawable/admin_ic_users" app:tint="@color/admin_blue" />
                </FrameLayout>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="10dp" android:layout_weight="1" android:maxLines="2" android:text="@string/manage_users" android:textColor="@color/admin_text_primary" android:textSize="13sp" android:textStyle="bold" />
                <ImageView android:layout_width="18dp" android:layout_height="18dp" android:contentDescription="@null" android:src="@drawable/role_ic_chevron_right" app:tint="@color/admin_text_muted" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/buttonAdminApprovals" style="@style/Widget.Smartkid.AdminGlassCard.Interactive"
            android:layout_width="0dp" android:layout_height="62dp" android:layout_columnWeight="1" android:layout_margin="5dp" app:cardCornerRadius="20dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center_vertical" android:orientation="horizontal" android:padding="10dp">
                <FrameLayout android:layout_width="36dp" android:layout_height="36dp" android:background="@drawable/admin_bg_quick_green">
                    <ImageView android:layout_width="18dp" android:layout_height="18dp" android:layout_gravity="center" android:contentDescription="@null" android:src="@drawable/admin_ic_approval" app:tint="@color/admin_green" />
                </FrameLayout>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="10dp" android:layout_weight="1" android:maxLines="2" android:text="@string/approve_courses" android:textColor="@color/admin_text_primary" android:textSize="13sp" android:textStyle="bold" />
                <ImageView android:layout_width="18dp" android:layout_height="18dp" android:contentDescription="@null" android:src="@drawable/role_ic_chevron_right" app:tint="@color/admin_text_muted" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/buttonAdminTransactions" style="@style/Widget.Smartkid.AdminGlassCard.Interactive"
            android:layout_width="0dp" android:layout_height="62dp" android:layout_columnWeight="1" android:layout_margin="5dp" app:cardCornerRadius="20dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center_vertical" android:orientation="horizontal" android:padding="10dp">
                <FrameLayout android:layout_width="36dp" android:layout_height="36dp" android:background="@drawable/admin_bg_quick_purple">
                    <ImageView android:layout_width="18dp" android:layout_height="18dp" android:layout_gravity="center" android:contentDescription="@null" android:src="@drawable/admin_ic_card" app:tint="@color/admin_primary" />
                </FrameLayout>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="10dp" android:layout_weight="1" android:maxLines="2" android:text="@string/view_transactions" android:textColor="@color/admin_text_primary" android:textSize="13sp" android:textStyle="bold" />
                <ImageView android:layout_width="18dp" android:layout_height="18dp" android:contentDescription="@null" android:src="@drawable/role_ic_chevron_right" app:tint="@color/admin_text_muted" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/buttonAdminHealth" style="@style/Widget.Smartkid.AdminGlassCard.Interactive"
            android:layout_width="0dp" android:layout_height="62dp" android:layout_columnWeight="1" android:layout_margin="5dp" app:cardCornerRadius="20dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center_vertical" android:orientation="horizontal" android:padding="10dp">
                <FrameLayout android:layout_width="36dp" android:layout_height="36dp" android:background="@drawable/admin_bg_quick_cyan">
                    <ImageView android:layout_width="18dp" android:layout_height="18dp" android:layout_gravity="center" android:contentDescription="@null" android:src="@drawable/admin_ic_settings" app:tint="@color/admin_cyan" />
                </FrameLayout>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="10dp" android:layout_weight="1" android:maxLines="2" android:text="@string/quick_system" android:textColor="@color/admin_text_primary" android:textSize="13sp" android:textStyle="bold" />
                <ImageView android:layout_width="18dp" android:layout_height="18dp" android:contentDescription="@null" android:src="@drawable/role_ic_chevron_right" app:tint="@color/admin_text_muted" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </GridLayout>
</merge>
