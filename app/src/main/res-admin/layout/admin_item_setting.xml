<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="14dp"
    android:paddingTop="13dp"
    android:paddingEnd="14dp"
    android:paddingBottom="13dp">
    <FrameLayout
        android:id="@+id/containerAdminSettingIcon"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/admin_bg_setting_icon">
        <ImageView
            android:id="@+id/imageAdminSettingIcon"
            android:layout_width="19dp"
            android:layout_height="19dp"
            android:layout_gravity="center"
            android:contentDescription="@null"
            app:tint="@color/admin_primary" />
    </FrameLayout>
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:background="@android:color/transparent"
        android:orientation="vertical">
        <TextView
            android:id="@+id/textAdminSettingTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:textColor="@color/admin_text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/textAdminSettingSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:background="@android:color/transparent"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/admin_text_secondary"
            android:textSize="11.5sp" />
    </LinearLayout>
    <ImageView
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:contentDescription="@null"
        android:src="@drawable/role_ic_chevron_right"
        app:tint="@color/admin_text_muted" />
</LinearLayout>
