<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:minHeight="64dp"
    android:orientation="horizontal"
    android:paddingTop="9dp"
    android:paddingBottom="9dp">

    <TextView
        android:id="@+id/textAdminCourseRank"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:background="@drawable/common_bg_avatar"
        android:gravity="center"
        android:textColor="@color/admin_header_end"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/textAdminCourseTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:maxLines="2"
        android:textColor="@color/smartkid_text"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/textAdminCourseEnrollments"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:textColor="@color/admin_header_end"
        android:textSize="12sp" />
</LinearLayout>
