<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scrollAdminSettings"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:fillViewport="true">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="16dp"
        android:paddingEnd="20dp"
        android:paddingBottom="112dp">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/admin_settings_title"
            android:textColor="@color/admin_text_primary"
            android:textSize="22sp"
            android:textStyle="bold" />
        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.Smartkid.AdminGlassCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            app:cardCornerRadius="24dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">
                <TextView
                    android:id="@+id/textAdminSettingsAvatar"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:background="@drawable/admin_bg_avatar"
                    android:gravity="center"
                    android:text="AD"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/textAdminSettingsName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@string/admin_role_name"
                        android:textColor="@color/admin_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/textAdminSettingsEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@string/admin_account_fallback"
                        android:textColor="@color/admin_text_secondary"
                        android:textSize="12.5sp" />
                </LinearLayout>
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="@null"
                    android:src="@drawable/admin_ic_approval"
                    app:tint="@color/admin_primary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="@string/admin_settings_security_title"
            android:textColor="@color/admin_text_primary"
            android:textSize="17sp"
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.Smartkid.AdminGlassCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:cardCornerRadius="24dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <include android:id="@+id/buttonAdminSettingsSecurity" layout="@layout/admin_item_setting" />
                <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginStart="62dp" android:layout_marginEnd="16dp" android:background="@color/admin_divider" />
                <include android:id="@+id/buttonAdminSettingsHealth" layout="@layout/admin_item_setting" />
                <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginStart="62dp" android:layout_marginEnd="16dp" android:background="@color/admin_divider" />
                <include android:id="@+id/buttonAdminSettingsConfig" layout="@layout/admin_item_setting" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:background="@drawable/admin_bg_logout_card"
            android:orientation="vertical"
            android:padding="16dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="@null"
                    android:src="@drawable/admin_ic_logout"
                    app:tint="@color/admin_red" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="9dp"
                    android:layout_weight="1"
                    android:text="@string/admin_end_session_title"
                    android:textColor="@color/admin_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/admin_end_session_subtitle"
                android:textColor="@color/admin_text_secondary"
                android:textSize="12.5sp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonAdminLogout"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="14dp"
                android:text="@string/logout"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textStyle="bold"
                app:backgroundTint="@color/admin_red"
                app:cornerRadius="16dp"
                app:icon="@drawable/admin_ic_logout"
                app:iconGravity="textStart"
                app:iconTint="@color/white" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
