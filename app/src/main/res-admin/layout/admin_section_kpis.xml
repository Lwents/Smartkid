<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <TextView
        style="@style/TextAppearance.Smartkid.Title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="22dp"
        android:layout_marginEnd="16dp"
        android:text="@string/admin_kpi_title"
        android:textSize="18sp" />

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="12dp"
        android:columnCount="3">

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.Smartkid.GlassCard"
            android:layout_width="0dp"
            android:layout_height="132dp"
            android:layout_columnWeight="1"
            android:layout_margin="3dp"
            app:cardBackgroundColor="@color/admin_card_blue">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="10dp">
                <ImageView
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:background="@drawable/common_bg_glass_capsule"
                    android:contentDescription="@null"
                    android:padding="7dp"
                    android:src="@drawable/admin_ic_users"
                    app:tint="@color/smartkid_primary" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="8dp"
                    android:layout_weight="1"
                    android:maxLines="2"
                    android:text="@string/admin_dau_label"
                    android:textColor="@color/smartkid_text_secondary"
                    android:textSize="10sp" />
                <TextView
                    android:id="@+id/textAdminDau"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/dashboard_zero"
                    android:textColor="@color/smartkid_text"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.Smartkid.GlassCard"
            android:layout_width="0dp"
            android:layout_height="150dp"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            app:cardBackgroundColor="@color/admin_card_green">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="12dp">
                <ImageView
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:background="@drawable/common_bg_glass_capsule"
                    android:contentDescription="@null"
                    android:padding="8dp"
                    android:src="@drawable/admin_ic_user_add"
                    app:tint="@color/smartkid_success" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="8dp"
                    android:layout_weight="1"
                    android:maxLines="2"
                    android:text="@string/admin_signups_label"
                    android:textColor="@color/smartkid_text_secondary"
                    android:textSize="11sp" />
                <TextView
                    android:id="@+id/textAdminSignups"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/dashboard_zero"
                    android:textColor="@color/smartkid_text"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.Smartkid.GlassCard"
            android:layout_width="0dp"
            android:layout_height="150dp"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            app:cardBackgroundColor="@color/admin_card_gold">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="12dp">
                <ImageView
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:background="@drawable/common_bg_glass_capsule"
                    android:contentDescription="@null"
                    android:padding="8dp"
                    android:src="@drawable/admin_ic_revenue"
                    app:tint="@color/smartkid_accent" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="8dp"
                    android:layout_weight="1"
                    android:maxLines="2"
                    android:text="@string/admin_revenue_label"
                    android:textColor="@color/smartkid_text_secondary"
                    android:textSize="11sp" />
                <TextView
                    android:id="@+id/textAdminRevenue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/dashboard_zero_currency"
                    android:textColor="@color/smartkid_text"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.Smartkid.GlassCard"
            android:layout_width="0dp"
            android:layout_height="150dp"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            app:cardBackgroundColor="@color/admin_card_cyan">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="12dp">
                <ImageView
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:background="@drawable/common_bg_glass_capsule"
                    android:contentDescription="@null"
                    android:padding="8dp"
                    android:src="@drawable/admin_ic_card"
                    app:tint="@color/smartkid_primary" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="8dp"
                    android:layout_weight="1"
                    android:maxLines="2"
                    android:text="@string/admin_transactions_label"
                    android:textColor="@color/smartkid_text_secondary"
                    android:textSize="11sp" />
                <TextView
                    android:id="@+id/textAdminTransactionsToday"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/dashboard_zero"
                    android:textColor="@color/smartkid_text"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.Smartkid.GlassCard"
            android:layout_width="0dp"
            android:layout_height="150dp"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            app:cardBackgroundColor="@color/admin_card_red">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="12dp">
                <ImageView
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:background="@drawable/common_bg_glass_capsule"
                    android:contentDescription="@null"
                    android:padding="8dp"
                    android:src="@drawable/admin_ic_refund"
                    app:tint="@color/smartkid_error" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="8dp"
                    android:layout_weight="1"
                    android:maxLines="2"
                    android:text="@string/admin_refund_label"
                    android:textColor="@color/smartkid_text_secondary"
                    android:textSize="11sp" />
                <TextView
                    android:id="@+id/textAdminRefundRate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/dashboard_zero_percent"
                    android:textColor="@color/smartkid_text"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.Smartkid.GlassCard"
            android:layout_width="0dp"
            android:layout_height="150dp"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            app:cardBackgroundColor="@color/admin_card_orange">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="12dp">
                <ImageView
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:background="@drawable/common_bg_glass_capsule"
                    android:contentDescription="@null"
                    android:padding="8dp"
                    android:src="@drawable/admin_ic_approval"
                    app:tint="@color/smartkid_accent" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="8dp"
                    android:layout_weight="1"
                    android:maxLines="2"
                    android:text="@string/admin_pending_label"
                    android:textColor="@color/smartkid_text_secondary"
                    android:textSize="11sp" />
                <TextView
                    android:id="@+id/textAdminPending"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/dashboard_zero"
                    android:textColor="@color/smartkid_text"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </GridLayout>
</merge>
