<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/adminDashboardRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/admin_bg_screen">

    <View
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="-90dp"
        android:layout_marginEnd="-80dp"
        android:background="@drawable/admin_bg_glow_blue" />

    <View
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_gravity="center_vertical|start"
        android:layout_marginStart="-120dp"
        android:background="@drawable/admin_bg_glow_green" />

    <View
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="-100dp"
        android:layout_marginBottom="120dp"
        android:background="@drawable/admin_bg_glow_purple" />

    <ViewFlipper
        android:id="@+id/adminPageFlipper"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <include layout="@layout/admin_page_dashboard" />
        <include layout="@layout/admin_page_users" />
        <include layout="@layout/admin_page_content" />
        <include layout="@layout/admin_page_settings" />
    </ViewFlipper>

    <FrameLayout
        android:id="@+id/adminBottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="@dimen/floating_nav_height"
        android:layout_gravity="bottom"
        android:layout_marginStart="@dimen/floating_nav_margin_horizontal"
        android:layout_marginEnd="@dimen/floating_nav_margin_horizontal"
        android:layout_marginBottom="@dimen/floating_nav_margin_bottom"
        android:background="@drawable/admin_bg_bottom_navigation"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:elevation="12dp"
        android:padding="4dp">

        <View
            android:id="@+id/adminNavSelectionIndicator"
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@drawable/admin_bg_nav_item_selected"
            android:clickable="false"
            android:elevation="0dp"
            android:focusable="false" />

        <LinearLayout
            android:id="@+id/adminBottomNavigationItems"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:baselineAligned="false"
            android:elevation="2dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/buttonAdminNavOverview"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:clickable="true"
                android:drawablePadding="2dp"
                android:focusable="true"
                android:gravity="center"
                android:maxLines="1"
                android:text="@string/admin_nav_overview"
                android:textColor="@color/admin_nav_item_color"
                android:textSize="10.5sp"
                android:textStyle="bold"
                app:drawableTint="@color/admin_nav_item_color"
                app:drawableTopCompat="@drawable/admin_ic_home" />

            <TextView
                android:id="@+id/buttonAdminNavUsers"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:clickable="true"
                android:drawablePadding="2dp"
                android:focusable="true"
                android:gravity="center"
                android:maxLines="1"
                android:text="@string/admin_nav_users"
                android:textColor="@color/admin_nav_item_color"
                android:textSize="10.5sp"
                android:textStyle="bold"
                app:drawableTint="@color/admin_nav_item_color"
                app:drawableTopCompat="@drawable/admin_ic_users" />

            <TextView
                android:id="@+id/buttonAdminNavContent"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:clickable="true"
                android:drawablePadding="2dp"
                android:focusable="true"
                android:gravity="center"
                android:maxLines="1"
                android:text="@string/admin_nav_content"
                android:textColor="@color/admin_nav_item_color"
                android:textSize="10.5sp"
                android:textStyle="bold"
                app:drawableTint="@color/admin_nav_item_color"
                app:drawableTopCompat="@drawable/admin_ic_course" />

            <TextView
                android:id="@+id/buttonAdminNavSettings"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:clickable="true"
                android:drawablePadding="2dp"
                android:focusable="true"
                android:gravity="center"
                android:maxLines="1"
                android:text="@string/admin_nav_settings"
                android:textColor="@color/admin_nav_item_color"
                android:textSize="10.5sp"
                android:textStyle="bold"
                app:drawableTint="@color/admin_nav_item_color"
                app:drawableTopCompat="@drawable/admin_ic_settings" />
        </LinearLayout>
    </FrameLayout>
</FrameLayout>
