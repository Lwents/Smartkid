<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/homeRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarHome"
        style="@style/Widget.Smartkid.GlassToolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:paddingStart="@dimen/screen_padding_compact"
        android:paddingEnd="@dimen/screen_padding_compact"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:title="@string/title_home" />

    <FrameLayout
        android:id="@+id/fragmentContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginBottom="92dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbarHome" />

    <LinearLayout
        android:id="@+id/bottomNavigation"
        style="@style/Widget.Smartkid.FloatingNavigation"
        android:layout_width="0dp"
        android:layout_height="@dimen/floating_nav_height"
        android:layout_marginStart="@dimen/floating_nav_margin"
        android:layout_marginEnd="@dimen/floating_nav_margin"
        android:layout_marginBottom="@dimen/floating_nav_margin"
        android:baselineAligned="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:background="@null"
            android:id="@+id/nav_dashboard"
            style="@style/Widget.Smartkid.FloatingNavigation.Item"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:contentDescription="@string/nav_home"
            app:drawableTopCompat="@drawable/home_ic_nav_glass_home"
            android:text="@string/nav_home" />

        <TextView
            android:background="@null"
            android:id="@+id/nav_courses"
            style="@style/Widget.Smartkid.FloatingNavigation.Item"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:contentDescription="@string/nav_courses"
            app:drawableTopCompat="@drawable/course_ic_nav_glass_courses"
            android:text="@string/nav_courses" />

        <TextView
            android:background="@null"
            android:id="@+id/nav_exams"
            style="@style/Widget.Smartkid.FloatingNavigation.Item"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:contentDescription="@string/nav_exams"
            app:drawableTopCompat="@drawable/exam_ic_nav_glass_exams"
            android:text="@string/nav_exams" />

        <TextView
            android:background="@null"
            android:id="@+id/nav_games"
            style="@style/Widget.Smartkid.FloatingNavigation.Item"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:contentDescription="@string/nav_games"
            app:drawableTopCompat="@drawable/game_ic_nav_glass_games"
            android:text="@string/nav_games" />

        <TextView
            android:background="@null"
            android:id="@+id/nav_profile"
            style="@style/Widget.Smartkid.FloatingNavigation.Item"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:contentDescription="@string/nav_profile"
            app:drawableTopCompat="@drawable/profile_ic_nav_glass_profile"
            android:text="@string/nav_profile" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
